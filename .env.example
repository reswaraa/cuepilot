# Copy to .env.local and fill in. .env.local is gitignored.

# Deepgram — server-only key, used by /api/deepgram/token to mint
# short-lived browser tokens for streaming STT.
DEEPGRAM_API_KEY=

# Sentry — error monitoring. Both are the same project DSN.
# The NEXT_PUBLIC_ one is exposed to the browser; SENTRY_DSN is server-only.
# Leave blank to disable Sentry locally.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Plausible — cookie-less analytics. Set to the registered domain
# (e.g. cuepilot.app). Leave blank to disable analytics locally.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
